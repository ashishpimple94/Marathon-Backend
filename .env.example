# Marathon Backend Environment Variables

# Server Configuration
PORT=5001

# PRIMARY SMTP SERVICE (Required for Production/Render)
# Hostinger Mail (Recommended for production)
HOSTINGER_USER=your-email@yourdomain.com
HOSTINGER_PASSWORD=your-hostinger-password

# FALLBACK SMTP SERVICES (Optional)
# SendGrid (Alternative option)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=your-verified-sender@yourdomain.com

# Zoho Mail (Alternative option)
ZOHO_USER=your-email@yourdomain.com
ZOHO_PASSWORD=your-zoho-password

# Gmail SMTP (Not recommended for Render deployment)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Email Recipients (Default configuration)
# All form submissions will be sent to these addresses
# TO_EMAIL=shubham@fitcover360.com
# CC_EMAIL=fitcover360@gmail.com

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your SMTP credentials (at least one service)
# 3. For production, use HOSTINGER_USER and HOSTINGER_PASSWORD
# 4. For development, you can use any of the SMTP services
# 5. Make sure to enable "Less secure app access" for Gmail if using Gmail SMTP
# 6. For Hostinger, use your email account credentials
# 7. For SendGrid, create an API key and verify your sender domain
# 8. For Zoho, use your Zoho Mail account credentials

# PRIORITY ORDER:
# 1. Hostinger Mail (Primary - Best for production)
# 2. SendGrid (Fallback)
# 3. Zoho Mail (Fallback)
# 4. Gmail SMTP (Last resort - not recommended for Render)